{
  "name": "inkling",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "vite build && wrangler deploy",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply inkling-db --local",
    "db:migrate": "wrangler d1 migrations apply inkling-db --remote",
    "lint": "oxlint src scripts *.config.ts --deny-warnings",
    "lint:fix": "oxlint src scripts *.config.ts --fix",
    "fmt": "oxfmt --write src scripts *.config.ts package.json tsconfig.json wrangler.jsonc",
    "fmt:check": "oxfmt --check src scripts *.config.ts package.json tsconfig.json wrangler.jsonc",
    "check": "pnpm run fmt:check && pnpm run lint && pnpm run typecheck && pnpm test",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@hono/zod-validator": "^0.7.6",
    "@lexical/code": "^0.22.0",
    "@lexical/history": "^0.22.0",
    "@lexical/link": "^0.22.0",
    "@lexical/list": "^0.22.0",
    "@lexical/markdown": "^0.22.0",
    "@lexical/plain-text": "^0.22.0",
    "@lexical/react": "^0.22.0",
    "@lexical/rich-text": "^0.22.0",
    "@lexical/utils": "^0.22.0",
    "@opentelemetry/api": "^1.9.1",
    "@tanstack/react-query": "^5.100.1",
    "@tanstack/react-router": "^1.168.24",
    "better-auth": "^1.6.11",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.18",
    "lexical": "^0.22.0",
    "lucide-react": "^1.8.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.36.2",
    "@cloudflare/workers-types": "^4.20260508.1",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-query-devtools": "^5.100.1",
    "@tanstack/router-devtools": "^1.166.13",
    "@tanstack/router-plugin": "^1.167.26",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "6.0.1",
    "better-sqlite3": "^12.9.0",
    "drizzle-kit": "^0.31.10",
    "jsdom": "^29.0.2",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.7.0",
    "vite": "8.0.12",
    "vitest": "^4.1.4",
    "wrangler": "^4.89.1"
  },
  "packageManager": "pnpm@10.33.0"
}
